{
  "$schema": "https://design-tokens.org/schema",
  "brand": {
    "name": "CuentaLimpia",
    "tagline": "Tu aliado financiero. Sin ansiedad."
  },
  "color": {
    "primary": {
      "default":  { "light": "#5B47E0", "dark": "#7C6BFF" },
      "hover":    { "light": "#4F3DCC", "dark": "#9080FF" },
      "press":    { "light": "#4131B5", "dark": "#6A57FF" },
      "subtle":   { "light": "#EEEBFF", "dark": "rgba(124,107,255,0.14)" },
      "contrast": { "light": "#FFFFFF", "dark": "#0B0B12" }
    },
    "income":  {
      "default":  { "light": "#059669", "dark": "#34D399" },
      "strong":   { "light": "#10B981", "dark": "#34D399" },
      "subtle":   { "light": "#D1FAE5", "dark": "rgba(52,211,153,0.14)" }
    },
    "expense": {
      "default":  { "light": "#DC2626", "dark": "#F87171" },
      "strong":   { "light": "#EF4444", "dark": "#F87171" },
      "subtle":   { "light": "#FEE2E2", "dark": "rgba(248,113,113,0.14)" }
    },
    "pending": {
      "default":  { "light": "#B45309", "dark": "#FBBF24" },
      "strong":   { "light": "#F59E0B", "dark": "#FBBF24" },
      "subtle":   { "light": "#FEF3C7", "dark": "rgba(251,191,36,0.14)" }
    },
    "info": {
      "default":  { "light": "#2563EB", "dark": "#60A5FA" },
      "strong":   { "light": "#3B82F6", "dark": "#60A5FA" },
      "subtle":   { "light": "#DBEAFE", "dark": "rgba(96,165,250,0.14)" }
    },
    "bg":          { "light": "#F8F8FB", "dark": "#0B0B12" },
    "surface":     { "light": "#FFFFFF", "dark": "#15151F" },
    "surface2":    { "light": "#F1F1F6", "dark": "#1C1C28" },
    "border":      { "light": "#E6E6EC", "dark": "#262633" },
    "borderStrong":{ "light": "#D1D1DA", "dark": "#33333F" },
    "fg1":         { "light": "#0B0B12", "dark": "#F4F4F8" },
    "fg2":         { "light": "#4A4A55", "dark": "#A1A1AD" },
    "fg3":         { "light": "#8A8A95", "dark": "#6B6B78" }
  },
  "gray": {
    "50":  { "light": "#F8F8FB", "dark": "#0B0B12" },
    "100": { "light": "#F1F1F6", "dark": "#15151F" },
    "200": { "light": "#E6E6EC", "dark": "#1C1C28" },
    "300": { "light": "#D1D1DA", "dark": "#262633" },
    "400": { "light": "#A1A1AD", "dark": "#4A4A55" },
    "500": { "light": "#8A8A95", "dark": "#6B6B78" },
    "600": { "light": "#4A4A55", "dark": "#A1A1AD" },
    "700": { "light": "#2E2E38", "dark": "#C6C6CE" },
    "800": { "light": "#1C1C28", "dark": "#E6E6EC" },
    "900": { "light": "#0B0B12", "dark": "#F4F4F8" }
  },
  "chart": {
    "series": ["#7C6BFF", "#10B981", "#F59E0B", "#3B82F6", "#EC4899", "#14B8A6", "#6366F1", "#F87171"]
  },
  "typography": {
    "fontFamily": {
      "sans": "Plus Jakarta Sans, ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica Neue, Arial, sans-serif",
      "mono": "ui-monospace, SFMono-Regular, JetBrains Mono, Menlo, Consolas, monospace"
    },
    "weights": [400, 500, 600, 700],
    "scale": {
      "display":     { "size": 40, "lineHeight": 44, "weight": 700, "tracking": "-0.02em" },
      "h1":          { "size": 28, "lineHeight": 34, "weight": 700, "tracking": "-0.01em" },
      "h2":          { "size": 22, "lineHeight": 28, "weight": 600, "tracking": "-0.01em" },
      "h3":          { "size": 18, "lineHeight": 24, "weight": 600, "tracking": "0" },
      "body":        { "size": 16, "lineHeight": 24, "weight": 400, "tracking": "0" },
      "bodyStrong":  { "size": 16, "lineHeight": 24, "weight": 600, "tracking": "0" },
      "label":       { "size": 14, "lineHeight": 20, "weight": 500, "tracking": "0" },
      "caption":     { "size": 12, "lineHeight": 16, "weight": 500, "tracking": "0.01em" },
      "mono":        { "size": 14, "lineHeight": 20, "weight": 500, "tracking": "0" }
    }
  },
  "spacing": {
    "base": 4,
    "scale": {
      "xs": 4, "sm": 8, "md": 12, "lg": 16,
      "xl": 24, "2xl": 32, "3xl": 48, "4xl": 64, "5xl": 96
    }
  },
  "breakpoints": {
    "mobile":  { "min": 375,  "columns": 4,  "gutter": 16, "margin": 16 },
    "tablet":  { "min": 768,  "columns": 8,  "gutter": 24, "margin": 24 },
    "desktop": { "min": 1280, "columns": 12, "gutter": 24, "margin": 32 }
  },
  "radius": {
    "sm": 6, "md": 10, "lg": 14, "xl": 20, "full": 9999
  },
  "shadow": {
    "xs": "0 1px 2px 0 rgba(11,11,18,0.04)",
    "sm": "0 1px 3px 0 rgba(11,11,18,0.06), 0 1px 2px -1px rgba(11,11,18,0.04)",
    "md": "0 4px 12px -2px rgba(11,11,18,0.08), 0 2px 6px -2px rgba(11,11,18,0.04)",
    "lg": "0 12px 32px -6px rgba(11,11,18,0.12)",
    "brand": "0 8px 24px -6px rgba(91,71,224,0.30)"
  },
  "motion": {
    "ease": "cubic-bezier(0.2, 0.8, 0.2, 1)",
    "duration": { "fast": "120ms", "base": "180ms", "slow": "240ms" }
  },
  "iconography": {
    "library": "lucide-react",
    "strokeWidth": 2,
    "sizes": [16, 20, 24, 32]
  }
}
